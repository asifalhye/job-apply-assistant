{
  "manifest_version": 3,
  "name": "Job Apply Assistant",
  "version": "0.1.0",
  "description": "Connects to local Job Apply Assistant app for form observation and fill suggestions.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3001/*", "http://localhost:5173/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Job Apply Assistant",
    "default_popup": "popup.html"
  }
}
